{
  "permissions": {
    "defaultMode": "acceptEdits",
    "allow": [
      "Bash(git status)",
      "Bash(git diff *)",
      "Bash(git log *)",
      "Bash(git show *)",
      "Bash(git stash *)",
      "Bash(git fetch *)",
      "Bash(git pull *)",
      "Bash(git checkout -b *)",

      "Bash(gh issue *)",
      "Bash(gh pr *)",
      "Bash(gh run *)",

      "Bash(pytest *)",
      "Bash(ruff check *)",
      "Bash(ruff format *)",

      "Bash(just lint)",

      "Bash(docker compose up *)"
    ],
    "deny": [
      "Bash(git checkout main *)",
      "Bash(rm -rf *)",
      "Bash(sudo *)",
      "Read(.env*)",
      "Write(*lock*)"
    ],
    "ask": [
      "Bash(git push *)"
    ]
  }
}
